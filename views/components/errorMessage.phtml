<?php

/**
 * Composant d'affichage d'erreur / notice utilisateur
 *
 * @var string|null $error Message d'erreur à afficher
 */
?>

<?php if ($notice): ?>
    <div class="card notice-card">
        <p class="notice-message">
            ℹ️ <?= htmlspecialchars($notice, ENT_QUOTES, 'UTF-8') ?>
        </p>
        <p class="notice-hint">
            💡 Utilisez la sélection par projet ci-dessus pour affiner votre recherche.
        </p>
    </div>
<?php endif; ?>

<?php if (!empty($error)): ?>
    <div class="card error-card">
        <div class="error-icon">⚠️</div>
        <div class="error-content">
            <h3>Une erreur s'est produite :</h3>
            <p><?= htmlspecialchars($error, ENT_QUOTES, 'UTF-8') ?></p>
        </div>
    </div>
<?php endif; ?>